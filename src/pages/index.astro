---
import Footer from '../components/layout/Footer';
import ContactWrapper from '../components/landing-page/contact/ContactWrapper';
import MapSection from '../components/landing-page/map/MapSection';
import WhenToConsult from '../components/landing-page/when-to-consult/WhenToConsult';
import agathePortrait from '../images/agathe.jpg';
import heroImage from '../images/dog-homepage.jpg';
import BaseLayout from '../layouts/BaseLayout.astro';
import AnimalSectionWrapper from '../layouts/wrappers/AnimalSectionWrapper.astro';
import DeroulementConsultationWrapper from '../layouts/wrappers/DeroulementConsultationWrapper.astro';
import HeroWrapper from '../layouts/wrappers/HeroWrapper.astro';
import OsteopathieAnimaleWrapper from '../layouts/wrappers/OsteopathieAnimaleWrapper.astro';
import PrixWrapper from '../layouts/wrappers/PrixWrapper.astro';
import QuiSuisJeWrapper from '../layouts/wrappers/QuiSuisJeWrapper.astro';
import {
  BUSINESS_CONFIG,
  SITE_CONFIG,
  buildFaqSchema,
  buildPersonSchema,
  getCanonicalUrl,
} from '../lib/constants/site';
import { faqItems } from '../lib/constants/siteArchitecture';

const title = SITE_CONFIG.title;
const description = SITE_CONFIG.description;
const siteUrl = SITE_CONFIG.url;
const canonicalUrl = getCanonicalUrl('/');

const homepageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    '@id': `${siteUrl}#local-business`,
    name: BUSINESS_CONFIG.name,
    description,
    url: siteUrl,
    image: [
      new URL(heroImage.src, siteUrl).toString(),
      new URL(agathePortrait.src, siteUrl).toString(),
    ],
    telephone: BUSINESS_CONFIG.telephone,
    email: BUSINESS_CONFIG.email,
    priceRange: BUSINESS_CONFIG.priceRange,
    address: {
      '@type': 'PostalAddress',
      ...BUSINESS_CONFIG.address,
    },
    geo: {
      '@type': 'GeoCoordinates',
      ...BUSINESS_CONFIG.geo,
    },
    openingHoursSpecification: BUSINESS_CONFIG.openingHoursSpecification.map((hours) => ({
      '@type': 'OpeningHoursSpecification',
      ...hours,
    })),
    areaServed: BUSINESS_CONFIG.areaServed,
    sameAs: BUSINESS_CONFIG.sameAs,
    founder: {
      '@type': 'Person',
      name: BUSINESS_CONFIG.practitionerName,
      jobTitle: BUSINESS_CONFIG.practitionerJobTitle,
    },
    contactPoint: {
      '@type': 'ContactPoint',
      contactType: 'customer support',
      telephone: BUSINESS_CONFIG.telephone,
      email: BUSINESS_CONFIG.email,
      availableLanguage: ['fr'],
      areaServed: 'FR',
    },
  },
  buildPersonSchema(),
  buildFaqSchema(faqItems.slice(0, 4)),
];
---

<BaseLayout
  title={title}
  description={description}
  siteUrl={siteUrl}
  canonicalUrl={canonicalUrl}
  schema={homepageSchema}
>
  <div>
    <main id="root">
      <HeroWrapper />
      <div id="animaux">
        <AnimalSectionWrapper />
      </div>
      <MapSection client:visible />
      <WhenToConsult id="quand-consulter" client:visible />
      <PrixWrapper id="tarifs" />
      <DeroulementConsultationWrapper />
      <OsteopathieAnimaleWrapper id="osteopathie" />
      <QuiSuisJeWrapper />
      <div class="recaptcha-wrapper">
        <ContactWrapper id="contact" client:visible />
      </div>
    </main>
    <Footer client:visible />
  </div>
</BaseLayout>
