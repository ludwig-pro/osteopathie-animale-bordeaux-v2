---
import MarketingPageLayout from '../layouts/MarketingPageLayout.astro';
import { animalHighlights, faqItems } from '../lib/constants/siteArchitecture';
import {
  buildBreadcrumbSchema,
  buildFaqSchema,
  buildPersonSchema,
  buildProfessionalServiceSchema,
  getCanonicalUrl,
} from '../lib/constants/site';

const canonicalPath = '/animaux';
const canonicalUrl = getCanonicalUrl(canonicalPath);
const title =
  'Animaux pris en charge en ostéopathie animale à Bordeaux | Agathe Lescout';
const description =
  "Chiens, chats, chevaux, bovins et NAC: découvrez les animaux pris en charge en ostéopathie animale à Bordeaux, Bègles et en Gironde.";
const schema = [
  buildProfessionalServiceSchema({ canonicalUrl, description }),
  buildPersonSchema(),
  buildBreadcrumbSchema([
    { name: 'Accueil', item: getCanonicalUrl('/') },
    { name: 'Animaux', item: canonicalUrl },
  ]),
  buildFaqSchema(faqItems.slice(0, 3)),
];
---

<MarketingPageLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  eyebrow="Animaux"
  introTitle="Quels animaux sont pris en charge en ostéopathie animale ?"
  introDescription="Les consultations concernent les chiens, chats, chevaux, bovins et nouveaux animaux de compagnie. Chaque espèce présente des contraintes mécaniques et comportementales différentes, ce qui demande une approche adaptée."
  breadcrumbs={[{ label: 'Animaux', href: canonicalPath }]}
  schema={schema}
>
  <section class="grid gap-6 md:grid-cols-2">
    {
      animalHighlights.map((animal) => (
        <article class="rounded-3xl border border-stone-200 bg-white p-6 shadow-sm">
          <h2 class="text-2xl font-bold text-canard">{animal.title}</h2>
          <p class="mt-3 text-stone-600">Motifs fréquents: {animal.reasons.join(', ')}.</p>
        </article>
      ))
    }
  </section>

  <section class="mt-12 grid gap-8 lg:grid-cols-2">
    <article class="rounded-3xl bg-gold-50 p-8">
      <h2 class="text-2xl font-bold text-canard">Quand prendre rendez-vous ?</h2>
      <p class="mt-4 leading-8 text-stone-700">
        Un bilan peut être pertinent en prévention, après un traumatisme, lors
        d'une boiterie, d'une baisse de performance, d'un trouble digestif, d'un
        changement de comportement ou après une période de croissance rapide.
      </p>
    </article>
    <article class="rounded-3xl bg-white p-8 shadow-sm ring-1 ring-stone-200">
      <h2 class="text-2xl font-bold text-canard">Cabinet ou domicile</h2>
      <p class="mt-4 leading-8 text-stone-700">
        Les consultations peuvent se dérouler au cabinet de Bègles ou à domicile
        autour de Bordeaux selon l'espèce, le motif de consultation et vos
        contraintes logistiques.
      </p>
      <div class="mt-6 flex flex-wrap gap-4">
        <a href="/cabinet-begles" class="rounded-full bg-gold-500 px-5 py-3 text-sm font-semibold text-white">
          Voir le cabinet
        </a>
        <a href="/#contact" class="rounded-full border border-gold-500 px-5 py-3 text-sm font-semibold text-gold-700">
          Demander un rendez-vous
        </a>
      </div>
    </article>
  </section>
</MarketingPageLayout>
