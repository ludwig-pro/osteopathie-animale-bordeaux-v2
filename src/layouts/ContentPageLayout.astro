---
import Footer from '../components/layout/Footer';
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  robots?: string | undefined;
}

const { title, description, robots } = Astro.props;
---

<BaseLayout title={title} description={description} robots={robots}>
  <main class="min-h-screen bg-gray-50">
    <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
      <a
        href="/"
        class="inline-flex items-center text-sm font-semibold text-gold-600 hover:text-gold-700"
      >
        Retour a l'accueil
      </a>
      <div class="mt-8 rounded-3xl bg-white p-8 shadow-sm ring-1 ring-gray-200 sm:p-12">
        <slot />
      </div>
    </section>
  </main>
  <Footer client:visible />
</BaseLayout>
