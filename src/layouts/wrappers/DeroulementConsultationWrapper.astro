---
import { getImage } from 'astro:assets';
import ConsultationProcess from '../../components/landing-page/consultation/ConsultationProcess';
import correction from '../../images/correction.jpg';
import youngcat from '../../images/yougncat.jpeg';

const youngcatImg = await getImage({
  src: youngcat,
  width: 800,
  format: 'webp',
  quality: 80,
});

const correctionImg = await getImage({
  src: correction,
  width: 800,
  format: 'webp',
  quality: 80,
});
---

<ConsultationProcess youngcatImg={youngcatImg} correctionImg={correctionImg} />
