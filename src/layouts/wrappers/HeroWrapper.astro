---
import { getImage } from 'astro:assets';
import Hero from '../../components/landing-page/hero/Hero';
import dogHomepage from '../../images/dog-homepage.jpg';

const widths = [768, 1024, 1920];

const webpImages = await Promise.all(
  widths.map((width) =>
    getImage({
      src: dogHomepage,
      width,
      format: 'webp',
      quality: 75,
    })
  )
);

const webpSrcset = webpImages
  .map((image, index) => `${image.src} ${widths[index]}w`)
  .join(', ');

const webpSrc = webpImages[webpImages.length - 1]?.src ?? '';
---

<Hero
  client:load
  backgroundSources={{
    webp: {
      src: webpSrc,
      srcset: webpSrcset,
    },
  }}
  backgroundAlt="Chien recevant un soin ostéopathique"
/>
