---
type BreadcrumbItem = {
  label: string;
  href: string;
};

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
const trail = [{ label: 'Accueil', href: '/' }, ...items];
---

<nav aria-label="Fil d'ariane" class="text-sm text-stone-500">
  <ol class="flex flex-wrap items-center gap-2">
    {
      trail.map((item, index) => (
        <>
          {index > 0 && <li aria-hidden="true">/</li>}
          <li>
            {index === trail.length - 1 ? (
              <span class="font-medium text-stone-700">{item.label}</span>
            ) : (
              <a href={item.href} class="hover:text-gold-600">
                {item.label}
              </a>
            )}
          </li>
        </>
      ))
    }
  </ol>
</nav>
