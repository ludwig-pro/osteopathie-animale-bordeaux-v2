---
interface Props {
  eyebrow?: string | undefined;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="border-b border-stone-200 bg-white">
  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    {eyebrow && (
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-gold-600">
        {eyebrow}
      </p>
    )}
    <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-canard sm:text-5xl">
      {title}
    </h1>
    <p class="mt-5 max-w-3xl text-lg leading-8 text-stone-600">{description}</p>
  </div>
</section>
